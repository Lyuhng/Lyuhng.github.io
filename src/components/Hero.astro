---
import { ExternalLink, FileText, GraduationCap, Mail, MapPin } from "lucide-astro";
import { profile } from "@/data/profile";
import { withBase } from "@/utils/site";

const links = [
  profile.email ? { label: "Email", href: `mailto:${profile.email}`, icon: Mail } : undefined,
  { label: "Google Scholar", href: profile.scholar, icon: GraduationCap },
  profile.github ? { label: "GitHub", href: profile.github, icon: ExternalLink } : undefined,
  profile.orcid ? { label: "ORCID", href: profile.orcid, icon: ExternalLink } : undefined,
  { label: "CV", href: withBase(profile.cv), icon: FileText }
].filter(Boolean);
---

<section class="container-page grid gap-10 pb-10 pt-12 md:grid-cols-[260px_1fr] md:pt-16">
  <aside class="md:sticky md:top-28 md:self-start">
    <div class="overflow-hidden rounded-lg border border-line bg-white shadow-soft">
      <img
        src={withBase(profile.avatar)}
        onerror={`this.onerror=null;this.src='${withBase(profile.fallbackAvatar)}';`}
        alt={`${profile.name} portrait`}
        class="aspect-[4/3] w-full object-cover"
      />
      <div class="space-y-4 p-5">
        <div>
          <h1 class="text-3xl font-semibold tracking-normal text-ink">{profile.name}</h1>
          <p class="mt-1 text-base text-muted">{profile.nameNative}</p>
        </div>
        <p class="text-sm leading-6 text-muted">{profile.role}</p>
        <div class="space-y-2 text-sm text-muted">
          <p class="flex gap-2">
            <GraduationCap class="mt-0.5 shrink-0 text-accent" size={17} stroke-width={1.8} />
            <span>{profile.affiliation}</span>
          </p>
          <p class="flex gap-2">
            <MapPin class="mt-0.5 shrink-0 text-accent" size={17} stroke-width={1.8} />
            <span>{profile.location}</span>
          </p>
        </div>
      </div>
    </div>
  </aside>

  <div class="min-w-0">
    <p class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-accent">Academic homepage</p>
    <h2 class="max-w-3xl text-4xl font-semibold tracking-normal text-ink sm:text-5xl">
      Non-coding RNAs, muscle biology, and lipid metabolism.
    </h2>
    <p class="prose-readable mt-6 max-w-3xl text-lg text-muted">{profile.bio}</p>

    <div class="mt-6 flex flex-wrap gap-2">
      {
        profile.interests.map((interest) => (
          <span class="rounded-lg border border-line bg-white px-3 py-1.5 text-sm font-medium text-muted">
            {interest}
          </span>
        ))
      }
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      {
        links.map((item) => {
          const Icon = item.icon;
          return (
            <a
              class="focus-ring inline-flex items-center gap-2 rounded-lg border border-line bg-white px-4 py-2 text-sm font-semibold text-accent-dark shadow-sm transition hover:border-accent/40 hover:bg-accent/5"
              href={item.href}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noreferrer" : undefined}
            >
              <Icon size={17} stroke-width={1.8} />
              {item.label}
            </a>
          );
        })
      }
    </div>

    <dl class="mt-10 grid max-w-2xl grid-cols-3 overflow-hidden rounded-lg border border-line bg-white text-center shadow-soft">
      <div class="border-r border-line p-4">
        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">Citations</dt>
        <dd class="mt-1 text-2xl font-semibold text-ink">{profile.metrics.citations}</dd>
      </div>
      <div class="border-r border-line p-4">
        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">h-index</dt>
        <dd class="mt-1 text-2xl font-semibold text-ink">{profile.metrics.hIndex}</dd>
      </div>
      <div class="p-4">
        <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-muted">i10-index</dt>
        <dd class="mt-1 text-2xl font-semibold text-ink">{profile.metrics.i10Index}</dd>
      </div>
    </dl>
    <p class="mt-3 text-xs text-muted">{profile.metrics.source}</p>
  </div>
</section>
