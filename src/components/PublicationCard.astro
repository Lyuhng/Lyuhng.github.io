---
import { BookOpen, Code2, FileText, Link as LinkIcon, Quote } from "lucide-astro";
import type { Publication } from "@/data/publications";

type Props = {
  publication: Publication;
};

const { publication } = Astro.props;

const linkItems = [
  publication.links.pdf ? { label: "PDF", href: publication.links.pdf, icon: FileText } : undefined,
  publication.links.code ? { label: "Code", href: publication.links.code, icon: Code2 } : undefined,
  publication.links.project ? { label: "Project", href: publication.links.project, icon: LinkIcon } : undefined,
  publication.links.bibtex ? { label: "BibTeX", href: publication.links.bibtex, icon: Quote } : undefined,
  publication.links.scholar ? { label: "Scholar", href: publication.links.scholar, icon: BookOpen } : undefined
].filter(Boolean);
---

<article class="rounded-lg border border-line bg-white p-5 shadow-soft">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div class="min-w-0">
      <div class="mb-2 flex flex-wrap items-center gap-2">
        <span class="rounded-md bg-accent/10 px-2 py-1 text-xs font-semibold text-accent-dark">{publication.type}</span>
        <span class="text-xs font-semibold text-muted">{publication.year}</span>
        {publication.selected && <span class="rounded-md bg-amber-100 px-2 py-1 text-xs font-semibold text-amber-800">Selected</span>}
      </div>
      <h3 class="text-lg font-semibold leading-7 text-ink">{publication.title}</h3>
    </div>
    {
      typeof publication.citations === "number" && (
        <div class="shrink-0 rounded-lg border border-line bg-paper px-3 py-2 text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.12em] text-muted">Cites</p>
          <p class="text-lg font-semibold text-ink">{publication.citations}</p>
        </div>
      )
    }
  </div>
  <p class="mt-3 text-sm leading-6 text-muted">{publication.authors}</p>
  <p class="mt-2 text-sm font-medium leading-6 text-ink">{publication.venue}</p>
  {publication.abstract && <p class="mt-3 text-sm leading-6 text-muted">{publication.abstract}</p>}
  <div class="mt-4 flex flex-wrap gap-2">
    {
      linkItems.map((item) => {
        const Icon = item.icon;
        return (
          <a class="focus-ring inline-flex items-center gap-1.5 rounded-lg border border-line px-3 py-1.5 text-xs font-semibold text-accent-dark transition hover:border-accent/40 hover:bg-accent/5" href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
            <Icon size={14} stroke-width={1.8} />
            {item.label}
          </a>
        );
      })
    }
  </div>
</article>
