---
type Props = {
  title: string;
  eyebrow?: string;
  description?: string;
  actionHref?: string;
  actionLabel?: string;
  id?: string;
  className?: string;
};

const { title, eyebrow, description, actionHref, actionLabel, id, className = "" } = Astro.props;
---

<section id={id} class:list={["container-page py-10", className]}>
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      {eyebrow && <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-accent">{eyebrow}</p>}
      <h2 class="text-2xl font-semibold tracking-normal text-ink sm:text-3xl">{title}</h2>
      {description && <p class="mt-3 max-w-3xl text-base leading-7 text-muted">{description}</p>}
    </div>
    {
      actionHref && actionLabel && (
        <a class="focus-ring shrink-0 rounded-lg border border-line bg-white px-4 py-2 text-sm font-semibold text-accent-dark shadow-sm transition hover:border-accent/40 hover:bg-accent/5" href={actionHref}>
          {actionLabel}
        </a>
      )
    }
  </div>
  <slot />
</section>
